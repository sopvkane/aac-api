# Database
DB_URL=jdbc:postgresql://localhost:5432/aac
DB_USER=app
DB_PASS=app

# Azure (placeholders for later AT3 branches, not used in AAC-07)
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_KEY=
AZURE_OPENAI_DEPLOYMENT=

# TTS provider: azure (default) or elevenlabs
# Use TTS_PROVIDER=elevenlabs (env vars prefer UPPER_SNAKE_CASE)
TTS_PROVIDER=elevenlabs

# ElevenLabs (when TTS_PROVIDER=elevenlabs) - free tier: ~10k chars/month
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=